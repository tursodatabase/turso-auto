{
  "name": "@tursodatabase/auto",
  "version": "0.1.0",
  "description": "Zero-config Turso database provisioning — a database for every user, agent, and tenant, on Turso Cloud or BYOC.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "ava",
    "test:conformance": "ava",
    "prepublishOnly": "npm run build"
  },
  "ava": {
    "files": [
      "conformance/**/*.test.ts"
    ],
    "extensions": [
      "ts"
    ],
    "nodeArguments": [
      "--import=tsx"
    ]
  },
  "keywords": [
    "turso",
    "sqlite",
    "database",
    "multi-tenant",
    "provisioning",
    "serverless",
    "edge"
  ],
  "author": "Turso",
  "license": "MIT",
  "dependencies": {
    "@tursodatabase/api": "^1.9.0",
    "@tursodatabase/serverless": "^1.2.0-pre.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ava": "^8.0.1",
    "tsx": "^4.22.4",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
