# Copy to conformance/.env and fill in to run the live conformance tests.
#
# Generate an API token:   turso auth api-tokens mint conformance
# Find your org slug:       turso org list
# Create/choose a group:    turso group create conformance

TURSO_API_TOKEN=your-api-token
TURSO_ORG=your-org-slug
TURSO_GROUP=your-group
